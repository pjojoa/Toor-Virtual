	<layer name="logomarval" url="botones/logom.png" scale="0.15" keep="true" vr="false" enabled="true" align="righttop" x="5" y="10" onclick="openurl('https://marval.com.co/',_blank);"/>

	
	<scene name="scene_alcoba_2" title="ALCOBA 2" onstart="" thumburl="panos/ALCOBA_2.tiles/thumb.jpg" lat="3.42900667" lng="-76.54739833" alt="1031.20" heading="0.0">
		
